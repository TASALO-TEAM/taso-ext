{
  "manifest_version": 3,
  "name": "TASALO",
  "short_name": "TASALO",
  "version": "0.2.1",
  "description": "Tasas de cambio Cuba - El Toque, BCC, Binance",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TASALO"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "omnibox": {
    "keyword": "tsl"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8040/*",
    "https://tasalo.duckdns.org/*"
  ]
}
