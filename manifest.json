{
  "manifest_version": 3,
  "name": "TASALO \u2014 Tasas de Cambio Cuba",
  "short_name": "TASALO",
  "version": "0.2.0",
  "description": "Tasas del mercado informal cubano en tiempo real. Escribe 'tsl' en la barra de direcciones.",
  "default_locale": "es",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TASALO \u2014 Tasas de Cambio"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "omnibox": {
    "keyword": "tsl"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8040/*",
    "https://api.tasalo.app/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@tasalo.app",
      "strict_min_version": "109.0"
    }
  }
}
